import random

# ============================================================
# 데이터셋 (변경 금지) -- 정답: H(x) = 0.5x + 2  (w=0.5, b=2)
# ============================================================
random.seed(42)
x_data = [i for i in range(1, 21)]
y_data = [0.5 * x + 2 + random.uniform(-0.3, 0.3) for x in x_data]
# ============================================================
# 학생 구현 영역
# ============================================================

# num of sample 변수 취득
N = len(x_data)

# 하이퍼파라미터 설정
epochs = 80
lr = 0.003
batch_size = 4

# 파라미터 초기화
w = 0.0
b = 0.0

# 러닝레이트 따른 변수
warmup_epochs = 15
decay_epochs = epochs - warmup_epochs

for epoch in range(1, epochs+1):
    # 샘플 섞기
    indices = list(range(N))
    random.shuffle(indices)

    # epoch 당 loss 초기화
    epoch_loss = 0.0

    if epoch < warmup_epochs:
        lr = lr * (epoch / warmup_epochs)
    else:
        lr = lr * (1 - (epoch - warmup_epochs) / decay_epochs)

    for start in range(0, N, batch_size):
        batch_indices = indices[start : start + batch_size]

        # 다음 for문 에서 파라미터 건드림
        # 기울기 초기화
        w_grad = 0.0
        b_grad = 0.0

        for index in batch_indices:
            # 각 index 마다 샘플 지정
            x = x_data[index]
            y = y_data[index]

            pred = w * x + b
            error = pred - y

            w_grad += 2 * x * error
            b_grad += 2 * error
            epoch_loss = error ** 2

        w_grad /= batch_size
        b_grad /= batch_size

        w = w - lr * w_grad
        b = b - lr * b_grad

    epoch_loss /= N

# ============================================================
# 1. 데이터셋
#    정답: H(x) = 0.5x + 2  →  w=0.5, b=2
# ============================================================
import random

x_data = [1, 2, 3, 4]
y_data = [2.5, 3.0, 3.5, 4.0]
num_of_samples = len(x_data)

epochs = 1000
learning_rate = 0.01

w = random.random()
b = random.random()

# epoch만큼 학습 순회하기
for epoch in range(1, epochs + 1): 
# ----------------------------------------------------------
    # (A) 가설 (Hypothesis): H(x) = wx + b
    #     모델이 현재 w, b로 예측한 값을 구한다.
#-----------------------------------------------------------
    w_grad = 0.0
    b_grad = 0.0
    loss = 0.0
    
    # sample을 순회
    for x, y in zip(x_data, y_data):

(B) 손실 함수 (Loss Function): MSE = (1/n) Σ (H(x) - y)²
    #     예측값과 실제값의 차이를 error 로 나타낸다
    #     이 값이 작을수록 정답에 가깝다
    # ----------------------------------------------------------

        # 예측 값 계산
        # H(x) = w * x + b
        predict = w * x + b
        
        # Error 계산
        error = predict - y
        
        # w의 기울기(Loss) 값 누적
        w_grad += 2 * x * error
        
        # b의 기울기(Loss) 값 누적
        b_grad += 2 * error
        
        # loss 값 누적
        loss += error ** 2

    # ----------------------------------------------------------
    # (C) 옵티마이저 (Optimizer): Gradient Descent
    #     손실 즉 loss 가 줄어드는 방향으로 w, b를 업데이트한다.
    #
    #     ∂Loss/∂w = (2/n) Σ (H(x) - y) · x
    #     ∂Loss/∂b = (2/n) Σ (H(x) - y)
    #
    #     관계 정리:
    #       가설 → 예측값 생성
    #       손실함수 → 예측이 얼마나 틀렸는지 측정
    #       옵티마이저 → 파라미터 수정
    # ----------------------------------------------------------
   
    # 기울기와 loss의 평균 구하기    
    w_grad /= num_of_samples
    b_grad /= num_of_samples
    loss /= num_of_samples
    
    # Update parameters
    w = w - learning_rate * w_grad
    b = b - learning_rate * b_grad
    
    if epoch % 100 == 0:
        print(f"epoch: {epoch}, loss: {loss:.4f}")


print(f"w: {w}, b: {b}")
        
print("예측 결과:")
for x, y in zip(x_data, y_data):
    pred = w * x + b
    print(f"  x={x} → 예측: {pred:.4f}, 정답: {y}")

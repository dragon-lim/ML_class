# 2부터 N까지 각 수가 소수인지 판별하여 출력하세요.
# 흐름: 입력 → 각 수 소수 판별(√i 최적화) → 소수 출력 → 개수 출력

def is_prime_number(num):
    """num이 소수이면 True, 아니면 False 반환"""
    if num < 2:
        return False
    for j in range(2, int(num**0.5) + 1):  # √num까지만 검사하여 효율 향상
        if num % j == 0:
            return False
    return True

# n으로 숫자 입력받음
n = int(input())
k = 0

for i in range(2, n + 1):
    if is_prime_number(i):
        k += 1
        print(i, end=" ")

print()
print(f"소수 개수: {k}")

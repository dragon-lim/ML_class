# 2 이상의 정수를 입력받아 소수 여부를 판별하세요.
num = int(input())

if num >= 2:
    for divisor in range(2 , num):
        if num % divisor ==0:
            print(f"{num}은(는) 소수가 아닙니다.")
            break
    else:    
        print(f"{num}은(는) 소수입니다.")


